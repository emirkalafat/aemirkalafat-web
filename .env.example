# Firebase Configuration
# Get these from your Firebase Console: Project Settings → Web App
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Media Lookup APIs
# Get from https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here
# Get from https://console.cloud.google.com (optional — Open Library is used as fallback)
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Status Page (Uptime Kuma)
# URL to your Uptime Kuma status page instance. Required at runtime (fetched
# directly from the browser in every environment, not just via the dev proxy) —
# the instance must send Access-Control-Allow-Origin, since this is a cross-origin request.
VITE_STATUS_PAGE_URL=https://info.example.com
# Refresh interval in milliseconds (default: 30000 = 30 seconds)
VITE_STATUS_REFRESH_INTERVAL=30000

# Minecraft Servers (Crafty Controller)
# Base URL of your Crafty Controller instance — uses the public GET /api/v2/servers/status
# endpoint (no auth). Required at runtime in every environment; the instance must send
# Access-Control-Allow-Origin, since this is a cross-origin request.
VITE_CRAFTY_API_URL=https://crafty.example.com
# Refresh interval in milliseconds (default: 30000 = 30 seconds)
VITE_CRAFTY_REFRESH_INTERVAL=30000
